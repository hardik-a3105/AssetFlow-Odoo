<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Report Action -->
    <record id="action_report_asset_label" model="ir.actions.report">
        <field name="name">Asset Labels</field>
        <field name="model">assetflow.asset</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">assetflow.report_asset_label_template</field>
        <field name="report_file">assetflow.report_asset_label_template</field>
        <field name="binding_model_id" ref="model_assetflow_asset"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Report Template -->
    <template id="report_asset_label_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="page" style="page-break-after: always; padding: 20px;">
                    <div style="border: 2px solid #4f46e5; border-radius: 8px; padding: 15px; width: 100%; max-width: 450px; margin: 0 auto; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #fafafa; box-shadow: 0 4px 6px rgba(0,0,0,0.05);">
                        <!-- Header banner -->
                        <div style="background-color: #4f46e5; color: white; padding: 8px 12px; margin: -15px -15px 15px -15px; border-top-left-radius: 6px; border-top-right-radius: 6px; font-weight: bold; text-align: center; letter-spacing: 1px;">
                            ASSETFLOW INVENTORY TAG
                        </div>
                        
                        <div class="row">
                            <!-- Left: Asset details -->
                            <div class="col-8" style="float: left; width: 65%;">
                                <div style="font-size: 16px; font-weight: bold; color: #1e1b4b; margin-bottom: 5px;">
                                    <span t-field="doc.name"/>
                                </div>
                                <div style="font-size: 12px; color: #4b5563; margin-bottom: 3px;">
                                    <strong>Inventory ID:</strong> <span t-field="doc.tag"/>
                                </div>
                                <div style="font-size: 12px; color: #4b5563; margin-bottom: 3px;">
                                    <strong>Category:</strong> <span t-field="doc.category_id.name"/>
                                </div>
                                <div style="font-size: 12px; color: #4b5563; margin-bottom: 3px;">
                                    <strong>Serial Number:</strong> <span t-field="doc.serial_no"/>
                                </div>
                                <div style="font-size: 12px; color: #4b5563; margin-bottom: 3px;">
                                    <strong>Location:</strong> <span t-field="doc.location"/>
                                </div>
                                <div style="font-size: 12px; color: #4b5563; margin-bottom: 3px;">
                                    <strong>Condition:</strong> <span t-field="doc.condition"/>
                                </div>
                            </div>
                            
                            <!-- Right: QR Code -->
                            <div class="col-4" style="float: right; width: 30%; text-align: center;">
                                <t t-if="doc.qr_code">
                                    <img t-att-src="image_data_uri(doc.qr_code)" style="max-width: 100px; max-height: 100px; border: 1px solid #e5e7eb; padding: 4px; border-radius: 4px; background-color: #fff;"/>
                                </t>
                                <t t-else="">
                                    <div style="font-size: 10px; color: #9ca3af; border: 1px dashed #d1d5db; padding: 10px; border-radius: 4px; height: 100px; display: flex; align-items: center; justify-content: center;">
                                        No QR Code
                                    </div>
                                </t>
                            </div>
                        </div>
                        
                        <div style="clear: both;"></div>
                        
                        <!-- Footer -->
                        <div style="border-top: 1px solid #e5e7eb; margin-top: 15px; padding-top: 8px; font-size: 9px; color: #9ca3af; text-align: center;">
                            Scan QR Code to view detailed info and history
                        </div>
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
