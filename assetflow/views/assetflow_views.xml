<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================== ASSET SEARCH VIEW ==================== -->
    <record id="view_asset_search" model="ir.ui.view">
        <field name="name">assetflow.asset.search</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <search string="Search Assets">
                <field name="name"/>
                <field name="tag"/>
                <field name="serial_no"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <filter string="Available" name="available" domain="[('state', '=', 'available')]"/>
                <filter string="Allocated" name="allocated" domain="[('state', '=', 'allocated')]"/>
                <filter string="Maintenance" name="maintenance" domain="[('state', '=', 'maintenance')]"/>
                <filter string="Bookable" name="bookable" domain="[('is_bookable', '=', True)]"/>
                <group expand="0" string="Group By">
                    <filter string="Category" name="group_by_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Status" name="group_by_status" context="{'group_by': 'state'}"/>
                    <filter string="Department" name="group_by_department" context="{'group_by': 'department_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== ASSET VIEWS ==================== -->
    <record id="view_asset_tree" model="ir.ui.view">
        <field name="name">assetflow.asset.tree</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <tree string="Assets">
                <field name="tag" help="Unique inventory tag identifier"/>
                <field name="name"/>
                <field name="category_id" help="Asset classification category"/>
                <field name="serial_no"/>
                <field name="condition" widget="badge" decoration-success="condition == 'good'" decoration-warning="condition == 'fair'" decoration-danger="condition == 'poor'" help="Current physical wear and tear rating"/>
                <field name="location" help="Assigned office room or physical floor location"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-info="state == 'allocated'" decoration-warning="state == 'maintenance'" decoration-danger="state in ('lost', 'retired', 'disposed', 'reserved')" help="Status color legend: Green = Available, Blue = Allocated, Orange = Maintenance, Red = Lost/Retired"/>
            </tree>
        </field>
    </record>

    <record id="view_asset_form" model="ir.ui.view">
        <field name="name">assetflow.asset.form</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <form string="Asset">
                <sheet>
                    <field name="tag" invisible="1"/>
                    <field name="qr_code" widget="image" class="oe_avatar" options="{'size': [90, 90]}" readonly="1" style="float: right; margin-right: 10px;" invisible="tag == 'New'"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Laptop Lenovo ThinkPad"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="category_id" help="Category classification of this asset"/>
                            <field name="serial_no" help="Manufacturer's serial number"/>
                            <field name="condition" help="Physical wear condition of this asset"/>
                            <field name="location" help="Current physical office room or floor location"/>
                        </group>
                        <group>
                            <field name="acquisition_date" help="Purchase/Acquisition date"/>
                            <field name="acquisition_cost" help="Purchase cost in USD"/>
                            <field name="is_bookable" help="Check this if this is a shared resource that can be booked via the calendar"/>
                            <field name="department_id" help="Asset department assignment"/>
                            <field name="state" help="Current lifecycle state (Green=Available, Blue=Allocated, Orange=Maintenance, Red=Lost/Retired)"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Depreciation &amp; Financials">
                            <group>
                                <group string="Asset Valuation">
                                    <field name="acquisition_cost" readonly="1"/>
                                    <field name="salvage_value"/>
                                    <field name="depreciation_years"/>
                                </group>
                                <group string="Current Financial Standing">
                                    <field name="accumulated_depreciation" readonly="1"/>
                                    <field name="book_value" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ==================== BOOKING VIEWS ==================== -->
    <record id="view_booking_calendar" model="ir.ui.view">
        <field name="name">assetflow.booking.calendar</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <calendar string="Resource Bookings" date_start="start_datetime" date_stop="end_datetime" color="resource_id" quick_create="false">
                <field name="employee_id"/>
                <field name="resource_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_booking_tree" model="ir.ui.view">
        <field name="name">assetflow.booking.tree</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <tree string="Resource Bookings">
                <field name="resource_id"/>
                <field name="employee_id"/>
                <field name="start_datetime"/>
                <field name="end_datetime"/>
                <field name="state" widget="badge" decoration-info="state == 'upcoming'" decoration-success="state == 'ongoing'" decoration-muted="state == 'completed'"/>
            </tree>
        </field>
    </record>

    <record id="view_booking_form" model="ir.ui.view">
        <field name="name">assetflow.booking.form</field>
        <field name="model">assetflow.booking</field>
        <field name="arch" type="xml">
            <form string="Resource Booking">
                <sheet>
                    <group>
                        <field name="resource_id"/>
                        <field name="employee_id"/>
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== MAINTENANCE VIEWS ==================== -->
    <record id="view_maintenance_kanban" model="ir.ui.view">
        <field name="name">assetflow.maintenance.kanban</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" records_draggable="true" quick_create="false">
                <field name="state"/>
                <field name="priority"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_kanban_card">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_title">
                                    <strong><field name="asset_id"/></strong>
                                </div>
                                <div class="o_kanban_record_body">
                                    <field name="issue"/>
                                </div>
                                <div class="o_kanban_record_bottom">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="priority" widget="priority"/>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="technician_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_maintenance_tree" model="ir.ui.view">
        <field name="name">assetflow.maintenance.tree</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests">
                <field name="asset_id"/>
                <field name="issue"/>
                <field name="priority" widget="badge" decoration-danger="priority == 'high'" decoration-warning="priority == 'medium'" decoration-info="priority == 'low'"/>
                <field name="technician_id"/>
                <field name="state" widget="badge" decoration-warning="state == 'pending'" decoration-info="state in ('approved', 'assigned', 'in_progress')" decoration-success="state == 'resolved'"/>
            </tree>
        </field>
    </record>

    <record id="view_maintenance_form" model="ir.ui.view">
        <field name="name">assetflow.maintenance.form</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id"/>
                            <field name="priority"/>
                        </group>
                        <group>
                            <field name="technician_id"/>
                            <field name="state" readonly="1"/>
                        </group>
                    </group>
                    <group string="Issue Description">
                        <field name="issue" placeholder="Describe the issue..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ==================== ALLOCATION VIEWS ==================== -->
    <record id="view_allocation_tree" model="ir.ui.view">
        <field name="name">assetflow.allocation.tree</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <tree string="Allocations">
                <field name="asset_id"/>
                <field name="employee_id"/>
                <field name="create_date" string="Allocation Date"/>
                <field name="expected_return_date"/>
                <field name="actual_return_date"/>
                <field name="state" widget="badge" decoration-success="state == 'active'" decoration-muted="state == 'returned'"/>
            </tree>
        </field>
    </record>

    <record id="view_allocation_form" model="ir.ui.view">
        <field name="name">assetflow.allocation.form</field>
        <field name="model">assetflow.allocation</field>
        <field name="arch" type="xml">
            <form string="Asset Allocation">
                <sheet>
                    <field name="asset_state" invisible="1"/>
                    <div class="alert alert-warning text-center" role="alert" invisible="asset_state != 'allocated'">
                        <strong>Warning!</strong> This asset is already allocated. Direct re-allocation is blocked.
                        Please use the button below to submit a transfer request.
                    </div>
                    <group>
                        <group>
                            <field name="asset_id" domain="[('state', 'in', ('available', 'allocated'))]"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="expected_return_date"/>
                            <field name="actual_return_date" invisible="state == 'active'"/>
                            <field name="state"/>
                        </group>
                    </group>
                    <group string="Condition Notes">
                        <field name="condition_notes"/>
                    </group>
                    <group invisible="asset_state != 'allocated'">
                        <button name="action_create_transfer" string="Create Transfer Request" type="object" class="btn-warning"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ==================== TRANSFER REQUEST VIEWS ==================== -->
    <record id="view_transfer_request_tree" model="ir.ui.view">
        <field name="name">assetflow.transfer.request.tree</field>
        <field name="model">assetflow.transfer.request</field>
        <field name="arch" type="xml">
            <tree string="Transfer Requests">
                <field name="asset_id"/>
                <field name="from_employee_id"/>
                <field name="to_employee_id"/>
                <field name="create_date" string="Request Date"/>
                <field name="state" widget="badge" decoration-warning="state == 'requested'" decoration-success="state == 'approved'" decoration-danger="state == 'rejected'"/>
            </tree>
        </field>
    </record>

    <record id="view_transfer_request_form" model="ir.ui.view">
        <field name="name">assetflow.transfer.request.form</field>
        <field name="model">assetflow.transfer.request</field>
        <field name="arch" type="xml">
            <form string="Asset Transfer Request">
                <header>
                    <button name="action_approve" string="Approve &amp; Reallocate" type="object" class="btn-success" invisible="state != 'requested'"/>
                    <button name="action_reject" string="Reject" type="object" class="btn-danger" invisible="state != 'requested'"/>
                    <field name="state" widget="statusbar" statusbar_visible="requested,approved,rejected,reallocated"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="asset_id" readonly="state != 'requested'"/>
                            <field name="from_employee_id" readonly="1" force_save="1"/>
                        </group>
                        <group>
                            <field name="to_employee_id" readonly="state != 'requested'"/>
                        </group>
                    </group>
                    <group string="Reason for Transfer">
                        <field name="reason" placeholder="Explain why this transfer is needed..." readonly="state != 'requested'"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== AUDIT CYCLE VIEWS ==================== -->
    <record id="view_audit_cycle_tree" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.tree</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <tree string="Audit Cycles">
                <field name="name"/>
                <field name="department_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="state" widget="badge" decoration-info="state == 'draft'" decoration-warning="state == 'in_progress'" decoration-success="state == 'closed'"/>
            </tree>
        </field>
    </record>

    <record id="view_audit_cycle_form" model="ir.ui.view">
        <field name="name">assetflow.audit.cycle.form</field>
        <field name="model">assetflow.audit.cycle</field>
        <field name="arch" type="xml">
            <form string="Audit Cycle">
                <header>
                    <button name="action_start" string="Start Audit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_close" string="Close Cycle" type="object" class="btn-success" invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,in_progress,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g. Q3 Engineering Audit"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id" readonly="state != 'draft'"/>
                            <field name="auditor_ids" widget="many2many_tags" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date_from" readonly="state != 'draft'"/>
                            <field name="date_to" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Asset Checklist">
                            <field name="line_ids" readonly="state == 'closed'">
                                <tree create="false" delete="false" editable="bottom">
                                    <field name="asset_id" readonly="1"/>
                                    <field name="expected_location" readonly="1"/>
                                    <field name="result" widget="badge" decoration-success="result == 'verified'" decoration-danger="result == 'missing'" decoration-warning="result == 'damaged'"/>
                                    <!-- Object buttons to set result quickly -->
                                    <button name="action_set_verified" string="Verify" type="object" class="btn-secondary" icon="fa-check text-success" invisible="parent.state != 'in_progress'"/>
                                    <button name="action_set_missing" string="Mark Missing" type="object" class="btn-secondary" icon="fa-times text-danger" invisible="parent.state != 'in_progress'"/>
                                    <button name="action_set_damaged" string="Mark Damaged" type="object" class="btn-secondary" icon="fa-exclamation text-warning" invisible="parent.state != 'in_progress'"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Discrepancy Summary" invisible="state == 'draft'">
                            <group>
                                <field name="discrepancy_summary" readonly="1" nolabel="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ==================== WINDOW ACTIONS ==================== -->
    <record id="action_assetflow_asset" model="ir.actions.act_window">
        <field name="name">Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_asset_search"/>
        <field name="target">current</field>
    </record>

    <record id="action_assetflow_allocation" model="ir.actions.act_window">
        <field name="name">Allocations</field>
        <field name="res_model">assetflow.allocation</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_assetflow_booking" model="ir.actions.act_window">
        <field name="name">Bookings</field>
        <field name="res_model">assetflow.booking</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_assetflow_maintenance" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_assetflow_audit_cycle" model="ir.actions.act_window">
        <field name="name">Audit Cycles</field>
        <field name="res_model">assetflow.audit.cycle</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <!-- ==================== REPORT VIEWS ==================== -->
    <!-- Utilization Report Views -->
    <record id="view_asset_pivot" model="ir.ui.view">
        <field name="name">assetflow.asset.pivot</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <pivot string="Asset Utilization">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_asset_graph" model="ir.ui.view">
        <field name="name">assetflow.asset.graph</field>
        <field name="model">assetflow.asset</field>
        <field name="arch" type="xml">
            <graph string="Asset Utilization" type="bar">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Maintenance Report Views -->
    <record id="view_maintenance_pivot" model="ir.ui.view">
        <field name="name">assetflow.maintenance.pivot</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <pivot string="Maintenance Frequency">
                <field name="category_id" type="row"/>
                <field name="state" type="col"/>
            </pivot>
        </field>
    </record>

    <record id="view_maintenance_graph" model="ir.ui.view">
        <field name="name">assetflow.maintenance.graph</field>
        <field name="model">assetflow.maintenance</field>
        <field name="arch" type="xml">
            <graph string="Maintenance Frequency" type="pie">
                <field name="category_id" type="row"/>
            </graph>
        </field>
    </record>

    <!-- Most Used Assets Tree View -->
    <record id="view_asset_tree_most_used" model="ir.ui.view">
        <field name="name">assetflow.asset.tree.most_used</field>
        <field name="model">assetflow.asset</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <tree string="Most-Used Assets" default_order="allocation_count desc" create="false" edit="false" delete="false">
                <field name="tag"/>
                <field name="name"/>
                <field name="category_id"/>
                <field name="allocation_count" string="Total Allocations"/>
                <field name="state" widget="badge" decoration-success="state == 'available'" decoration-info="state == 'allocated'" decoration-warning="state == 'maintenance'" decoration-danger="state in ('lost', 'retired', 'disposed', 'reserved')"/>
            </tree>
        </field>
    </record>

    <!-- Window Actions: Reports -->
    <record id="action_report_asset_utilization" model="ir.actions.act_window">
        <field name="name">Asset Utilization</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">pivot,graph</field>
        <field name="target">current</field>
    </record>

    <record id="action_report_maintenance_frequency" model="ir.actions.act_window">
        <field name="name">Maintenance Frequency</field>
        <field name="res_model">assetflow.maintenance</field>
        <field name="view_mode">pivot,graph</field>
        <field name="target">current</field>
    </record>

    <record id="action_report_idle_assets" model="ir.actions.act_window">
        <field name="name">Idle Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', '=', 'available')]</field>
        <field name="target">current</field>
    </record>

    <record id="action_report_most_used_assets" model="ir.actions.act_window">
        <field name="name">Most-Used Assets</field>
        <field name="res_model">assetflow.asset</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_asset_tree_most_used"/>
        <field name="target">current</field>
    </record>

    <!-- ==================== SUB-MENUS ==================== -->
    <menuitem id="menu_assetflow_assets" name="Assets" parent="menu_assetflow_root" action="action_assetflow_asset" sequence="15"/>
    <menuitem id="menu_assetflow_allocations" name="Allocations" parent="menu_assetflow_root" action="action_assetflow_allocation" sequence="16"/>
    <menuitem id="menu_assetflow_bookings" name="Bookings" parent="menu_assetflow_root" action="action_assetflow_booking" sequence="17"/>
    <menuitem id="menu_assetflow_maintenance" name="Maintenance" parent="menu_assetflow_root" action="action_assetflow_maintenance" sequence="18"/>
    <menuitem id="menu_assetflow_audit_cycle" name="Audit Cycles" parent="menu_assetflow_root" action="action_assetflow_audit_cycle" sequence="19"/>
    
    <!-- Parent Menu: Reports -->
    <menuitem id="menu_assetflow_reports" name="Reports &amp; Analytics" parent="menu_assetflow_root" sequence="40"/>
    
    <!-- Sub-menus under Reports -->
    <menuitem id="menu_report_asset_utilization" name="Asset Utilization" parent="menu_assetflow_reports" action="action_report_asset_utilization" sequence="1"/>
    <menuitem id="menu_report_maintenance_frequency" name="Maintenance Frequency" parent="menu_assetflow_reports" action="action_report_maintenance_frequency" sequence="2"/>
    <menuitem id="menu_report_idle_assets" name="Idle Assets" parent="menu_assetflow_reports" action="action_report_idle_assets" sequence="3"/>
    <menuitem id="menu_report_most_used_assets" name="Most-Used Assets" parent="menu_assetflow_reports" action="action_report_most_used_assets" sequence="4"/>
</odoo>
