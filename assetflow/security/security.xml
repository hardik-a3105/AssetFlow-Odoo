<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Security Category -->
    <record id="module_category_assetflow" model="ir.module.category">
        <field name="name">AssetFlow</field>
        <field name="description">Category for AssetFlow management</field>
        <field name="sequence">20</field>
    </record>

    <!-- Employee Group -->
    <record id="group_assetflow_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <!-- Department Head Group -->
    <record id="group_assetflow_dept_head" model="res.groups">
        <field name="name">Department Head</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <!-- Asset Manager Group -->
    <record id="group_assetflow_manager" model="res.groups">
        <field name="name">Asset Manager</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <!-- Admin Group -->
    <record id="group_assetflow_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_assetflow"/>
        <field name="implied_ids" eval="[(4, ref('group_assetflow_dept_head')), (4, ref('group_assetflow_manager'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Link Odoo Base Groups to automatically grant access -->
    <record id="base.group_user" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_assetflow_admin'))]"/>
    </record>

    <!-- RECORD RULES -->

    <!-- Asset Rules -->
    <record id="rule_assetflow_asset_employee" model="ir.rule">
        <field name="name">Employee Asset Rule</field>
        <field name="model_id" ref="model_assetflow_asset"/>
        <field name="domain_force">['|', ('is_bookable', '=', True), '&amp;', ('allocation_ids.employee_id', '=', user.id), ('allocation_ids.state', '=', 'active')]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="rule_assetflow_asset_dept_head" model="ir.rule">
        <field name="name">Dept Head Asset Rule</field>
        <field name="model_id" ref="model_assetflow_asset"/>
        <field name="domain_force">['|', '|', ('is_bookable', '=', True), ('department_id', '=', user.department_id.id), '&amp;', ('allocation_ids.employee_id', '=', user.id), ('allocation_ids.state', '=', 'active')]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
    </record>

    <record id="rule_assetflow_asset_manager" model="ir.rule">
        <field name="name">Manager Asset Rule</field>
        <field name="model_id" ref="model_assetflow_asset"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_manager')), (4, ref('group_assetflow_admin'))]"/>
    </record>

    <!-- Allocation Rules -->
    <record id="rule_assetflow_allocation_employee" model="ir.rule">
        <field name="name">Employee Allocation Rule</field>
        <field name="model_id" ref="model_assetflow_allocation"/>
        <field name="domain_force">[('employee_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="rule_assetflow_allocation_dept_head" model="ir.rule">
        <field name="name">Dept Head Allocation Rule</field>
        <field name="model_id" ref="model_assetflow_allocation"/>
        <field name="domain_force">['|', '|', ('department_id', '=', user.department_id.id), ('employee_id.department_id', '=', user.department_id.id), ('employee_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
    </record>

    <record id="rule_assetflow_allocation_manager" model="ir.rule">
        <field name="name">Manager Allocation Rule</field>
        <field name="model_id" ref="model_assetflow_allocation"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_manager')), (4, ref('group_assetflow_admin'))]"/>
    </record>

    <!-- Booking Rules -->
    <record id="rule_assetflow_booking_employee" model="ir.rule">
        <field name="name">Employee Booking Rule</field>
        <field name="model_id" ref="model_assetflow_booking"/>
        <field name="domain_force">[('employee_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="rule_assetflow_booking_dept_head" model="ir.rule">
        <field name="name">Dept Head Booking Rule</field>
        <field name="model_id" ref="model_assetflow_booking"/>
        <field name="domain_force">['|', ('employee_id.department_id', '=', user.department_id.id), ('employee_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
    </record>

    <record id="rule_assetflow_booking_manager" model="ir.rule">
        <field name="name">Manager Booking Rule</field>
        <field name="model_id" ref="model_assetflow_booking"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_manager')), (4, ref('group_assetflow_admin'))]"/>
    </record>

    <!-- Maintenance Rules -->
    <record id="rule_assetflow_maintenance_employee" model="ir.rule">
        <field name="name">Employee Maintenance Rule</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="domain_force">['|', ('create_uid', '=', user.id), ('technician_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="rule_assetflow_maintenance_dept_head" model="ir.rule">
        <field name="name">Dept Head Maintenance Rule</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="domain_force">['|', '|', ('asset_id.department_id', '=', user.department_id.id), ('create_uid', '=', user.id), ('technician_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
    </record>

    <record id="rule_assetflow_maintenance_manager" model="ir.rule">
        <field name="name">Manager Maintenance Rule</field>
        <field name="model_id" ref="model_assetflow_maintenance"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_manager')), (4, ref('group_assetflow_admin'))]"/>
    </record>

    <!-- Transfer Request Rules -->
    <record id="rule_assetflow_transfer_employee" model="ir.rule">
        <field name="name">Employee Transfer Rule</field>
        <field name="model_id" ref="model_assetflow_transfer_request"/>
        <field name="domain_force">['|', '|', ('from_employee_id', '=', user.id), ('to_employee_id', '=', user.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_employee'))]"/>
    </record>

    <record id="rule_assetflow_transfer_dept_head" model="ir.rule">
        <field name="name">Dept Head Transfer Rule</field>
        <field name="model_id" ref="model_assetflow_transfer_request"/>
        <field name="domain_force">['|', '|', ('from_employee_id.department_id', '=', user.department_id.id), ('to_employee_id.department_id', '=', user.department_id.id), ('create_uid', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_dept_head'))]"/>
    </record>

    <record id="rule_assetflow_transfer_manager" model="ir.rule">
        <field name="name">Manager Transfer Rule</field>
        <field name="model_id" ref="model_assetflow_transfer_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_assetflow_manager')), (4, ref('group_assetflow_admin'))]"/>
    </record>
</odoo>
