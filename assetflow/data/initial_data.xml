<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- ==================== PRODUCTION BASELINE DEPARTMENTS ==================== -->
    <record id="dept_engineering" model="assetflow.department">
        <field name="name">Engineering</field>
        <field name="code">ENG</field>
        <field name="status">active</field>
    </record>

    <record id="dept_finance" model="assetflow.department">
        <field name="name">Finance &amp; Accounts</field>
        <field name="code">FIN</field>
        <field name="status">active</field>
    </record>

    <record id="dept_admin" model="assetflow.department">
        <field name="name">Administration</field>
        <field name="code">ADM</field>
        <field name="status">active</field>
    </record>

    <!-- ==================== PRODUCTION BASELINE CATEGORIES ==================== -->
    <record id="cat_laptops" model="assetflow.category">
        <field name="name">Laptops &amp; Workstations</field>
        <field name="warranty_period">36</field>
    </record>

    <record id="cat_furniture" model="assetflow.category">
        <field name="name">Office Furniture</field>
        <field name="warranty_period">60</field>
    </record>

    <record id="cat_mobiles" model="assetflow.category">
        <field name="name">Mobile Devices</field>
        <field name="warranty_period">24</field>
    </record>

    <record id="cat_servers" model="assetflow.category">
        <field name="name">Server Infrastructure</field>
        <field name="warranty_period">48</field>
    </record>
</odoo>
