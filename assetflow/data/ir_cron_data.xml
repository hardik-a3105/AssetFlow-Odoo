<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_predictive_maintenance" model="ir.cron">
            <field name="name">AssetFlow: Routine Maintenance Scheduler</field>
            <field name="model_id" ref="model_assetflow_asset"/>
            <field name="state">code</field>
            <field name="code">model._run_predictive_maintenance_cron()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>

        <record id="ir_cron_overdue_alerts" model="ir.cron">
            <field name="name">AssetFlow: Overdue Return Alerts Scheduler</field>
            <field name="model_id" ref="model_assetflow_allocation"/>
            <field name="state">code</field>
            <field name="code">model._run_overdue_alerts_cron()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
